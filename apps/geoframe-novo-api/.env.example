DB_NAME=geoframe
DB_USER=geoframe_adm
DB_PASSWORD=
DB_HOST=lpostdes14.procempa.com.br
DB_PORT=6000
DB_SCHEMA=gfr_app

# Usada para investigar/fazer acoes por fora, por exemplo via Bruno/Postman/cURL
API_KEY_ENABLED=true
API_KEY_ID=
API_KEY_SECRET=

# Explorador de arquivos: credenciais do MinIO
MINIO_ENDPOINT=mapaspoa-minio.procempa.com.br
MINIO_ACCESS_KEY=mapaspoa
MINIO_SECRET_KEY=

USER_KC_TO_DEBBUG=
PASS_KC_TO_DEBBUG=

# GeoServer (GWC) local - teste de performance comparando com o Martin.
# host.docker.internal: GeoServer roda no host, fora do container da API.
GEOSERVER_BASE_URL=http://host.docker.internal:8083/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver

# -----------------------------------------------------------------------------
# API FastAPI
# -----------------------------------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
RUN_MIGRATIONS=true
AUTH_DEV_BYPASS=false
API_CORS_ORIGINS=http://localhost

GEOSERVER_GRIDSET=EPSG:900913
