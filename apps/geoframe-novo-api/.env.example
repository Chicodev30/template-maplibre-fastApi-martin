MINIO_ACCESS_KEY=mapaspoa
MINIO_SECRET_KEY=

USER_KC_TO_DEBBUG=
PASS_KC_TO_DEBBUG=

# -----------------------------------------------------------------------------
# API FastAPI
# -----------------------------------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
