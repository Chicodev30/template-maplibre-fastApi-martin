# GeoFrame Next - variaveis de ambiente de exemplo
# Infra separada: sem docker-compose, sem k8s e sem container local de PostgreSQL.
# O banco PostgreSQL/PostGIS sera informado por ENV.

# -----------------------------------------------------------------------------
# API FastAPI
# -----------------------------------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
RUN_MIGRATIONS=true
AUTH_DEV_BYPASS=false
API_CORS_ORIGINS=http://localhost
DB_NAME=geoframe
DB_USER=geoframe_adm
DB_PASSWORD=
DB_HOST=lpostdes14.procempa.com.br
DB_PORT=6000
DB_SCHEMA=smftest

# Papeis que o usuario tera de permissao configurados no Keycloak
KC_ROLE_VISUALIZADOR=gfr-visualizador
KC_ROLE_ADMIN=gfr-admin
KC_ROLE_CONTRIBUIDOR=gfr-contribuidor

# Usada para investigar/fazer acoes por fora, por exemplo via Bruno/Postman/cURL
API_KEY_ENABLED=true
API_KEY_ID=78d39e614b8c4528a90c434a0f6ea46a
API_KEY_SECRET=czHX62Vb7nhY96RpgB4/jGS7iE8EV3tgKptxu845aYXLP+Nkhb0UIDbBdznWtwxA

# Martin visto pela API
MARTIN_INTERNAL_URL=http://geoframe-martin:3000

# -----------------------------------------------------------------------------
# Web React/Vite
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api
VITE_AUTH_DEV_BYPASS=false
VITE_APP_TITLE=GeoFrame

# -----------------------------------------------------------------------------
# Martin
# -----------------------------------------------------------------------------
MARTIN_LISTEN_ADDRESSES=0.0.0.0:3000
MARTIN_DEFAULT_SRID=4326
MARTIN_AUTO_PUBLISH_TABLES=true
